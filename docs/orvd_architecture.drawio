<mxfile host="Electron" agent="Mozilla/5.0">
  <diagram id="page-1" name="Страница-1">
    <mxGraphModel dx="3473" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontStyle=1;fontSize=16;fontColor=#000000;" value="Базовая архитектура системы ОрВД БАС" vertex="1">
          <mxGeometry height="34" width="840" x="380" y="20" as="geometry" />
        </mxCell>
        <mxCell id="3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=11;fontColor=#000000;" value="Диаграмма для diagrams.net: ТЗ, требования безопасности и архитектура" vertex="1">
          <mxGeometry height="24" width="910" x="345" y="54" as="geometry" />
        </mxCell>
        <mxCell id="5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fontColor=#000000;fillColor=#d9ead3;" value="&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;ЦБ:&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;1. выполняются только авторизованные команды управления полетами БАС&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;2. Вылет БАС разрешается только при наличии авторизованной миссии&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;3. При любых обстоятельствах БАС не выполняют полеты в запретных зонах&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;4. Система обеспечивает возможность отзыва разрешения на полет и принудительной посадки БАС&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;5. Орвд использует только подлинные и целостные данные о состоянии БАС&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;6. Все события фиксируются с указанием времен, источника&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;ПБ:&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;1. Внешние системы (БАС, эксплуатанты) являются благонадежными и не скомпрометированы на момент взаимодействия с Орвд&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;2. Брокер сообщений обеспечивает доставку сообщений без искажения, не допускает несанкционированного доступа к топикам&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;3. идентификаторы БАС, миссий и сертификатов являются уникальным и не могут быть подделаны или повторно использованы&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;4. телеметрия, передаваемая БАС, отражает реальное состояние и не подменяется&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="600" width="550" x="1010" y="370" as="geometry" />
        </mxCell>
        <mxCell id="7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=none;fontStyle=1;fontSize=14;fontColor=#000000;" value="Наша система ОрВД БАС" vertex="1">
